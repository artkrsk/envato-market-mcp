{
  "name": "@artemsemkin/envato-market-mcp",
  "version": "1.2.1",
  "packageManager": "pnpm@10.33.0",
  "description": "MCP server for the Envato Market API",
  "author": "Artem Semkin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artkrsk/envato-market-mcp.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "envato-market-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "deps:check": "pnpm dlx npm-check-updates",
    "deps:update": "pnpm dlx npm-check-updates -u && pnpm install"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "@types/node": "^25.5.2"
  }
}
